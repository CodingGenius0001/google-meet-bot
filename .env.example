DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/meetbot"

# Dashboard authentication (NextAuth + Google OAuth).
# NEXTAUTH_URL should be the public URL of the dashboard in production.
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Comma-separated list of Google account emails allowed to sign in.
# If empty, sign-in is refused for everyone (fail closed).
DASHBOARD_ALLOWED_EMAILS=""

# Hosted LLM summarization (recommended — free, fast, open-source models).
# Defaults target Groq's free tier running Llama 3.3 70B. Works with any
# OpenAI-compatible endpoint (Groq, OpenRouter, Together, DeepInfra, HF
# Inference, Cloudflare Workers AI). Leave LLM_API_KEY empty to disable.
#
#   Groq:      https://console.groq.com/keys
#   OpenRouter: https://openrouter.ai/keys      (set LLM_BASE_URL=https://openrouter.ai/api/v1)
LLM_API_KEY=""
LLM_BASE_URL="https://api.groq.com/openai/v1"
LLM_MODEL="llama-3.3-70b-versatile"
# Extra providers beyond the built-in allow-list (comma-separated hostnames).
LLM_ALLOWED_HOSTS=""

# Optional self-hosted Ollama fallback. Host must be loopback or listed in
# OLLAMA_ALLOWED_HOSTS. Used only if the hosted LLM call above is not
# configured or fails.
OLLAMA_HOST=""
OLLAMA_MODEL=""
OLLAMA_ALLOWED_HOSTS=""

BLOB_READ_WRITE_TOKEN=""
GOOGLE_MEET_STORAGE_STATE_PATH="worker/.auth/google-user.json"
GOOGLE_MEET_STORAGE_STATE_BASE64=""
GOOGLE_MEET_GUEST_NAME="MeetMate Bot"

WORKER_SUMMON_URL=""
WORKER_SUMMON_TOKEN=""
WORKER_SUMMON_TIMEOUT_MS="15000"
WORKER_POLL_INTERVAL_MS="0"

PLAYWRIGHT_HEADLESS="false"
SOLO_GRACE_PERIOD_MS="60000"
JOIN_TIMEOUT_MS="180000"
# Hard cap on a single recording duration. Default 4h.
MAX_RECORDING_DURATION_MS="14400000"

TRANSCRIPTION_SEGMENT_SECONDS="900"
# Matches the path the Dockerfile installs whisper-cli to.
WHISPER_CPP_BINARY="/opt/whisper.cpp/bin/whisper-cli"
WHISPER_MODEL_PATH="/opt/whisper.cpp/models/ggml-tiny.en.bin"
WHISPER_LANGUAGE="en"
WHISPER_THREADS="4"
WORKER_PORT="8080"
DISPLAY=":99"
PULSE_SOURCE="default"
