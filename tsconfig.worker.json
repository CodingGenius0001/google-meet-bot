{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "es2022"],
    "module": "commonjs",
    "moduleResolution": "node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "worker/src/**/*.ts",
    "lib/ai.ts",
    "lib/env.ts",
    "lib/prisma.ts",
    "lib/retry.ts",
    "lib/storage.ts"
  ]
}
